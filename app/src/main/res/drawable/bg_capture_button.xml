            </item>
            <item android:top="8dp" android:bottom="8dp" android:left="8dp" android:right="8dp">
                <shape android:shape="oval">
                    <solid android:color="@color/primary_teal" />
                </shape>
            </item>
        </layer-list>
    </item>
