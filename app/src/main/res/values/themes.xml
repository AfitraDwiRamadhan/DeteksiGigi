<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CekGigi" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Main theme colors -->
        <item name="colorPrimary">@color/primary_teal</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary_teal</item>

        <!-- Status bar and nav bar -->
        <item name="android:statusBarColor">@color/background_light</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/background_white</item>

        <!-- Window backgrounds -->
        <item name="android:windowBackground">@color/background_light</item>

        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.CekGigi.Button.Primary</item>
        <item name="materialCardViewStyle">@style/Widget.CekGigi.Card</item>
    </style>
    
    <style name="Theme.CekGigi.Welcome">
        <item name="android:statusBarColor">@color/welcome_gradient_start</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/welcome_gradient_start</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.CekGigi.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/corner_radius_large</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/primary_teal</item>
        <item name="elevation">4dp</item>
    </style>
    
    <style name="Widget.CekGigi.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/corner_radius_large</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="strokeColor">@color/primary_teal</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/primary_teal</item>
    </style>
    
    <!-- Cards -->
    <style name="Widget.CekGigi.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/corner_radius_card</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="android:layout_marginBottom">@dimen/margin_medium</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.CekGigi.Headline" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_title</item>
    </style>

    <style name="TextAppearance.CekGigi.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
    </style>
</resources>
